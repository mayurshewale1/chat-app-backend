# ===========================================
# Chat App Backend - Environment Variables
# ===========================================
# Copy to .env and fill in your values
# NEVER commit .env to git
# ===========================================

# Server
NODE_ENV=production
PORT=4000

# PostgreSQL (Neon)
# Get from: https://console.neon.tech → Your Project → Connection details
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Frontend URL (for CORS & Socket.io)
# Use your frontend domain in production
FRONTEND_URL=https://yourdomain.com

# JWT (required in production)
# Generate: openssl rand -base64 32
JWT_SECRET=your-strong-random-secret-here

# JWT token expiry (optional) - 15m default; use 24h or 7d for longer sessions
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Logging (optional)
LOG_LEVEL=info
